# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /app

COPY ROFit.Api/ROFit.Api.csproj ROFit.Api/
COPY ROFit.Service/ROFit.Service.csproj ROFit.Service/
COPY ROFit.DAL/ROFit.DAL.csproj ROFit.DAL/
COPY ROFit.common/ROFit.common.csproj ROFit.common/
COPY ROFit.Model/ROFit.Model.csproj ROFit.Model/
COPY ROFit.Model.Common/ROFit.Model.Common.csproj ROFit.Model.Common/
COPY ROFit.Repository/ROFit.Repository.csproj ROFit.Repository/
COPY ROFit.Repository.Common/ROFit.Repository.Common.csproj ROFit.Repository.Common/
COPY ROFit.Service.Common/ROFit.Service.Common.csproj ROFit.Service.Common/

RUN dotnet restore ROFit.Api/ROFit.Api.csproj

COPY . .

RUN dotnet publish ROFit.Api/ROFit.Api.csproj \
    -c Release \
    -o out \
    -r linux-x64 \
    --self-contained false \
    /p:PublishTrimmed=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/out ./

# Railway port
ENV ASPNETCORE_URLS=http://*:$PORT
EXPOSE 8080

ENTRYPOINT ["dotnet", "ROFit.Api.dll"]